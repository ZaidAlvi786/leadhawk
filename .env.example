# LeadHawk v2 — Environment Variables
# Copy this file to .env.local and fill in your keys.

# ---------------------------------------------------------------------
# AI providers (one is required — Gemini recommended, OpenRouter fallback)
# ---------------------------------------------------------------------

# Google Gemini — generous free tier (15 req/min, 1500/day)
# Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional: override the default Gemini model (defaults to gemini-2.5-flash)
GOOGLE_MODEL=gemini-2.5-flash

# OpenRouter fallback — cycles through free models when Gemini fails
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: comma-separated list of OpenRouter model IDs to try in order
OPENROUTER_MODELS=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=2000

# App identity for OpenRouter referer header (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LeadHawk

# ---------------------------------------------------------------------
# Supabase (Phase 8 — required for cloud sync; optional otherwise)
# ---------------------------------------------------------------------
# Auth + Postgres database for multi-device sync. Without these, the app
# runs in localStorage-only mode (single browser, no sync).
#
# Setup:
#   1. Create a Supabase project at https://supabase.com
#   2. Project Settings → API: copy the URL + anon key below
#   3. SQL Editor: run supabase/migrations/001_initial_schema.sql
#   4. Restart the dev server
#   5. Open /analytics, scroll to "Sync" panel, click "First-time migrate"

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
